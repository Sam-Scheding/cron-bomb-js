{
  "name": "cron-bomb",
  "version": "3.1.0",
  "description": "A TypeScript-first library for generating recurring events from cron expressions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build && node -e \"require('fs').accessSync('dist/index.js')\"",
    "test": "jest --coverage",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo": "npx ts-node demo.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sam-Scheding/cron-bomb-js.git"
  },
  "keywords": [
    "npm",
    "cron",
    "dates",
    "typescript",
    "recurring events",
    "repeat",
    "repeating",
    "repeating events",
    "repeat events"
  ],
  "author": "Sam Scheding",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sam-Scheding/cron-bomb-js/issues"
  },
  "homepage": "https://github.com/Sam-Scheding/cron-bomb-js#readme",
  "dependencies": {
    "cron-parser": "^5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0"
  },
  "engines": {
    "node": ">=18"
  }
}
